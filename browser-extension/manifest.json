{
  "manifest_version": 3,
  "name": "Rising — Property Tracker",
  "version": "1.0.0",
  "description": "See your savings progress while browsing Zillow. Track property prices and how much you need to save.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.zillow.com/*",
    "https://*.realtor.com/*",
    "https://*.redfin.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zillow.com/*",
        "https://www.realtor.com/*",
        "https://www.redfin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
